  "refresh_24819_20260703": {
    "question_id": 24819,
    "question_text": "Will the USMCA be extended promptly at its July 2026 joint review?",
    "question_type": "binary",
    "probability": 0.35,
    "original_prob": 0.72,
    "change_pts": -37.0,
