    for symbol in WATCHLIST:
        if symbol in committed:
            action = 'position' if symbol in position_symbols else 'order already working'
            print(f"Skipping {symbol} — {action}")
            continue

        print(f"Analysing {symbol}...")
        mdata = build_market_data(symbol)
        if mdata is None:
            print(f"  Insufficient data — skipping")
            continue

        try:
            result = get_signal(symbol, mdata, macro)
        except Exception as e:
            print(f"  Signal error: {e}")
            continue

        decision   = result.get('decision', 'HOLD')
        direction  = result.get('direction', 'none')
        confidence = float(result.get('confidence', 0.0))
        risk       = result.get('risk', 'MEDIUM')
        reasoning  = result.get('reasoning', '')
        key_risk   = result.get('key_risk', '')

        coin_wr  = win_rates.get(symbol)
        leverage = calculate_leverage(confidence, coin_wr) \
                   if decision in ('BUY', 'SELL') else BASE_LEVERAGE

        dir_label = {'long': 'LONG ', 'short': 'SHORT', 'none': '     '}.get(direction, '     ')
        print(f"  {decision:<4} {dir_label} | Conf: {confidence:.0%} | "
              f"Lev: {leverage}x | Risk: {risk} | "
              f"Funding: {mdata['funding_rate']:+.4f}% | "
              f"OI: {mdata['oi_change']:+.1f}%")
        print(f"  {reasoning[:110]}")

        # Log every coin to scan_log
        append_csv(SCAN_LOG, SCAN_HEADERS, {
            'scan_date':        now.strftime('%Y-%m-%d'),
            'scan_time':        now.strftime('%H:%M:%S'),
            'symbol':           symbol,
            'price':            mdata['price'],
            'decision':         decision,
            'direction':        direction,
            'confidence':       round(confidence, 4),
            'leverage':         leverage,
            'risk':             risk,
            'momentum_24h':     mdata['momentum_24h'],
            'momentum_7d':      mdata['momentum_7d'],
            'volume_trend_pct': mdata['volume_trend'],
            'rsi':              mdata['rsi'],
            'funding_rate':     mdata['funding_rate'],
            'oi_change_pct':    mdata['oi_change'],
            'reasoning':        reasoning[:200],
        })

        # Queue as candidate if signal is actionable
        if decision in ('BUY', 'SELL') and confidence >= CONFIDENCE_THRESHOLD:
            # Skip HIGH risk trades unless confidence is very high
            if risk == 'HIGH' and confidence < 0.82:
                print(f"  Skipping HIGH risk trade (confidence {confidence:.0%} < 82% threshold)")
                continue
            candidates.append({
                'symbol':       symbol,
                'direction':    direction,
                'price':        mdata['price'],
                'leverage':     leverage,
                'confidence':   confidence,
                'risk':         risk,
                'funding_rate': mdata['funding_rate'],
                'oi_change':    mdata['oi_change'],
                'key_risk':     key_risk,
            })

        time.sleep(0.4)   # gentle rate limiting between coins

    # ── Place orders ──────────────────────────────────────────────────────────
    print(f"\n{'='*57}")
    print(f"BUY/SELL candidates: {len(candidates)}")

    # Sort by confidence descending — best signals first
    candidates.sort(key=lambda x: x['confidence'], reverse=True)

    trades_placed = 0
    for c in candidates:
        if trades_placed >= available_slots:
            print("Available slots filled.")
            break

        symbol    = c['symbol']
        direction = c['direction']
        price     = c['price']
        leverage  = c['leverage']
        confidence = c['confidence']
        coin      = symbol.replace('USDT', '')

        tp = round_price(symbol, price * (1 + TAKE_PROFIT_PCT) if direction == 'long'
                         else price * (1 - TAKE_PROFIT_PCT))
        sl = round_price(symbol, price * (1 - STOP_LOSS_PCT) if direction == 'long'
                         else price * (1 + STOP_LOSS_PCT))
        notional = POSITION_SIZE_USDT * leverage

        print(f"\nPlacing {direction.upper()} — {coin}:")
        print(f"  Entry:       {price}")
        print(f"  Take profit: {tp}  ({'+' if direction=='long' else '-'}{TAKE_PROFIT_PCT*100:.0f}%)")
        print(f"  Stop loss:   {sl}  ({'-' if direction=='long' else '+'}{STOP_LOSS_PCT*100:.0f}%)")
        print(f"  Leverage:    {leverage}x  (margin ${POSITION_SIZE_USDT} → notional ~${notional:.0f})")
        print(f"  Confidence:  {confidence:.0%}  |  Risk: {c['risk']}")
        print(f"  Funding:     {c['funding_rate']:+.4f}%  |  OI change: {c['oi_change']:+.1f}%")
        print(f"  Key risk:    {c['key_risk']}")

        try:
            order_id, qty, notional_actual, tp_actual, sl_actual = place_order(
                symbol, direction, price, leverage
            )
            print(f"  ✓ Order placed: {order_id}")

            append_csv(TRADE_LOG, TRADE_HEADERS, {
                'trade_date':    now.strftime('%Y-%m-%d'),
                'trade_time':    now.strftime('%H:%M:%S'),
                'symbol':        symbol,
                'direction':     direction,
                'entry_price':   price,
                'qty':           qty,
                'notional_usdt': round(notional_actual, 2),
                'margin_usdt':   POSITION_SIZE_USDT,
                'leverage':      leverage,
                'take_profit':   tp_actual,
                'stop_loss':     sl_actual,
                'confidence':    round(confidence, 4),
                'funding_rate':  c['funding_rate'],
                'oi_change_pct': c['oi_change'],
                'order_id':      order_id,
            })
            print(f"  Logged to {TRADE_LOG}")
            trades_placed += 1

        except Exception as e:
            print(f"  ✗ Order failed: {e}")

        time.sleep(0.5)

    # ── Summary ───────────────────────────────────────────────────────────────
    skipped = len([s for s in WATCHLIST if s in committed])
    analysed = len(WATCHLIST) - skipped
    print(f"\n{'='*57}")
    print(f"Scan complete: {analysed} coins analysed ({skipped} skipped)")
    print(f"Signals: {len(candidates)} actionable | Trades placed: {trades_placed}")
    print(f"Logs: {LOG_DIR}/")
    print("Done.")

if __name__ == '__main__':
    main()
