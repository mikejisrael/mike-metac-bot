# ─── Technical indicators ──────────────────────────────────────────────────────

def compute_rsi(closes: list, period: int = 14) -> float:
    """Standard Wilder RSI."""
    if len(closes) < period + 1:
        return 50.0
    gains, losses = [], []
    for i in range(-period, 0):
        diff = closes[i] - closes[i - 1]
        gains.append(max(diff, 0.0))
        losses.append(max(-diff, 0.0))
    avg_gain = sum(gains) / period
    avg_loss = sum(losses) / period
    if avg_loss == 0:
        return 100.0
    return round(100 - (100 / (1 + avg_gain / avg_loss)), 1)

def build_market_data(symbol: str) -> dict | None:
    """
    Fetch and compute all inputs for Claude's signal prompt.
    Returns None if insufficient data or API error.
    """
    try:
        candles = get_klines(symbol)
        if len(candles) < 10:
            return None

        closes  = [float(c[4]) for c in candles]
        volumes = [float(c[5]) for c in candles]
        highs   = [float(c[2]) for c in candles]
        lows    = [float(c[3]) for c in candles]
        price   = closes[-1]

        # Momentum: 24h = last 6 candles (6 × 4h), 7d = last 42 candles
        c24  = closes[-7]  if len(closes) >= 7  else closes[0]
        c7d  = closes[-43] if len(closes) >= 43 else closes[0]
        momentum_24h = (closes[-1] - c24)  / c24  * 100
        momentum_7d  = (closes[-1] - c7d)  / c7d  * 100

        # Distance from 7d high/low
        lb           = min(42, len(candles))
        high_7d      = max(highs[-lb:])
        low_7d       = min(lows[-lb:])
        pct_from_high = (price - high_7d) / high_7d * 100
        pct_from_low  = (price - low_7d)  / low_7d  * 100

        # 24h range
        high_24h = max(highs[-7:]) if len(highs) >= 7 else max(highs)
        low_24h  = min(lows[-7:])  if len(lows)  >= 7 else min(lows)

        # Volume trend: recent 2 candles vs 7d average
        avg_vol      = sum(volumes[-lb:]) / lb
        recent_vol   = sum(volumes[-2:]) / 2
        volume_trend = ((recent_vol - avg_vol) / avg_vol * 100) if avg_vol else 0.0

        rsi = compute_rsi(closes)

        # Ticker for funding rate (live)
        ticker       = get_ticker(symbol)
        funding_rate = float(ticker.get('fundingRate', 0)) * 100  # convert to %

        # Open interest 4h change
        oi_list   = get_open_interest(symbol)
        oi_change = 0.0
        if len(oi_list) >= 2:
            oi_now  = float(oi_list[0].get('openInterest', 0))
            oi_prev = float(oi_list[1].get('openInterest', 0))
            oi_change = ((oi_now - oi_prev) / oi_prev * 100) if oi_prev else 0.0

        return {
            'price':         price,
            'momentum_24h':  round(momentum_24h, 2),
            'momentum_7d':   round(momentum_7d, 2),
            'pct_from_high': round(pct_from_high, 2),
            'pct_from_low':  round(pct_from_low, 2),
            'volume_trend':  round(volume_trend, 1),
            'rsi':           rsi,
            'funding_rate':  round(funding_rate, 4),
            'oi_change':     round(oi_change, 2),
            'high_24h':      high_24h,
            'low_24h':       low_24h,
        }

    except Exception as e:
        print(f"  Data error for {symbol}: {e}")
        return None

# ─── Leverage calculation ──────────────────────────────────────────────────────

def load_coin_win_rates() -> dict:
    """
    Read closed_trades.csv and compute historical win rate per symbol.
    Only used once at scan start.
    """
    stats = {}
    if not os.path.exists(CLOSED_TRADE_LOG):
        return stats
    with open(CLOSED_TRADE_LOG, 'r', encoding='utf-8') as f:
        for row in csv.DictReader(f):
            sym = row['symbol']
            stats.setdefault(sym, {'wins': 0, 'total': 0})
            stats[sym]['total'] += 1
            if row['outcome'] == 'WIN':
                stats[sym]['wins'] += 1
    return {
        sym: v['wins'] / v['total']
        for sym, v in stats.items() if v['total'] >= 3   # need ≥3 trades to use
    }

def calculate_leverage(confidence: float, coin_win_rate: float | None) -> int:
    """
    Dynamic leverage between BASE_LEVERAGE and MAX_LEVERAGE.
    confidence   : Claude's signal confidence (0–1)
    coin_win_rate: historical win rate for this coin (None = use 0.5 default)
    
    Formula: weighted score drives linear interpolation from base to max.
    Score below 0.60 → base leverage only.
    Score at 1.0    → max leverage.
    """
    wr    = coin_win_rate if coin_win_rate is not None else 0.5
    score = confidence * 0.65 + wr * 0.35
    if score <= 0.60:
        return BASE_LEVERAGE
    scale    = (score - 0.60) / 0.40          # 0.0 → 1.0
    leverage = BASE_LEVERAGE + (MAX_LEVERAGE - BASE_LEVERAGE) * scale
    return int(min(MAX_LEVERAGE, max(BASE_LEVERAGE, round(leverage))))

# ─── Claude signal generation ──────────────────────────────────────────────────
_claude = anthropic.Anthropic(api_key=ANTHROPIC_API_KEY)

def get_signal(symbol: str, mdata: dict, macro: dict) -> dict:
    """
    Ask Claude Haiku to analyse market data for one coin.
    Returns parsed JSON dict with keys: decision, direction, confidence,
    risk, reasoning, key_risk.
    """
    coin = symbol.replace('USDT', '')

    prompt = f"""You are a professional crypto trading analyst specialising in perpetual futures.
Analyse the data below for {coin}/USDT and return a JSON trading signal.

MACRO ENVIRONMENT:
- Fear & Greed Index: {macro['fear_greed']} — {macro['fear_greed_label']}
- BTC Dominance: {macro['btc_dominance']}%
- Market regime: {macro['regime']}

TECHNICAL DATA ({coin}):
- Price:              {mdata['price']}
- 24h momentum:       {mdata['momentum_24h']:+.2f}%
- 7d momentum:        {mdata['momentum_7d']:+.2f}%
- Distance from 7d high: {mdata['pct_from_high']:.2f}%
- Distance from 7d low:  {mdata['pct_from_low']:.2f}%
- Volume trend vs 7d avg: {mdata['volume_trend']:+.1f}%
- RSI (14):           {mdata['rsi']}

MARKET STRUCTURE:
- Funding rate:       {mdata['funding_rate']:+.4f}% per 8h
  (positive = longs paying shorts; negative = shorts paying longs)
- Open interest 4h change: {mdata['oi_change']:+.2f}%
- 24h range:          {mdata['low_24h']} – {mdata['high_24h']}

DECISION RULES:
- BUY (open long):  clear uptrend, volume confirming, momentum positive,
                    funding rate not excessively positive (< +0.15%)
- SELL (open short): clear downtrend, momentum negative, volume confirming,
                     funding rate not excessively negative (> -0.15%)
- HOLD: mixed signals, insufficient conviction, or conditions contradict signal

RISK RULES:
- Mark HIGH risk if: RSI > 75 or < 25, funding rate extreme (> ±0.15%),
  large sudden OI spike (> ±20%), or coin is low-liquidity
- Extreme funding (> +0.15%) warns against longs (squeeze risk)
- Extreme negative funding (< -0.15%) warns against shorts (squeeze risk)
- Rising OI + rising price = strong trend confirmation
- Falling OI + rising price = weak trend (lack of conviction)

Return ONLY valid JSON — no markdown, no explanation outside the JSON:
{{
  "decision":   "BUY" | "SELL" | "HOLD",
  "direction":  "long" | "short" | "none",
  "confidence": 0.00–1.00,
  "risk":       "LOW" | "MEDIUM" | "HIGH",
  "reasoning":  "2-3 sentence summary of the signal",
  "key_risk":   "single biggest risk to this specific trade"
}}"""

    response = _claude.messages.create(
        model='claude-haiku-4-5-20251001',
        max_tokens=350,
        messages=[{'role': 'user', 'content': prompt}],
    )
    text = response.content[0].text.strip()
    text = text.replace('```json', '').replace('```', '').strip()
    return json.loads(text)

# ─── Order placement ───────────────────────────────────────────────────────────

def set_leverage(symbol: str, leverage: int):
    """Set leverage for symbol. Silently ignores 'not modified' errors."""
    lev = str(leverage)
    try:
        bybit_post('/v5/position/set-leverage', {
            'category':    'linear',
            'symbol':      symbol,
            'buyLeverage': lev,
            'sellLeverage': lev,
        })
    except ValueError as e:
        if '110043' not in str(e):   # 110043 = leverage already at this value
            raise

def place_order(symbol: str, direction: str, price: float,
                leverage: int) -> tuple:
    """
    Place a limit order with attached TP and SL.
    Returns (order_id, qty, notional, tp_price, sl_price).
    """
    side = 'Buy' if direction == 'long' else 'Sell'

    # TP / SL prices
    if direction == 'long':
        tp_price = round_price(symbol, price * (1 + TAKE_PROFIT_PCT))
        sl_price = round_price(symbol, price * (1 - STOP_LOSS_PCT))
    else:
        tp_price = round_price(symbol, price * (1 - TAKE_PROFIT_PCT))
        sl_price = round_price(symbol, price * (1 + STOP_LOSS_PCT))

    # Qty = notional / price, respecting exchange step size
    notional = POSITION_SIZE_USDT * leverage
    raw_qty  = notional / price
    qty      = round_qty(symbol, raw_qty)
    notional_actual = qty * price

    set_leverage(symbol, leverage)

    result = bybit_post('/v5/order/create', {
        'category':    'linear',
        'symbol':      symbol,
        'side':        side,
        'orderType':   'Limit',
        'qty':         str(qty),
        'price':       str(round_price(symbol, price)),
        'timeInForce': 'GTC',
        'takeProfit':  str(tp_price),
        'stopLoss':    str(sl_price),
        'tpTriggerBy': 'LastPrice',
        'slTriggerBy': 'LastPrice',
        'positionIdx': 0,            # one-way mode
    })
    return result.get('orderId', ''), qty, notional_actual, tp_price, sl_price

# ─── Account helpers ───────────────────────────────────────────────────────────

def get_positions() -> list:
    """Open positions with non-zero size."""
    result = bybit_get('/v5/position/list', {
        'category':   'linear',
        'settleCoin': 'USDT',
    }, auth=True)
    return [p for p in result.get('list', []) if float(p.get('size', 0)) != 0]

def get_open_orders() -> list:
    """All active/pending orders."""
    result = bybit_get('/v5/order/realtime', {
        'category':   'linear',
        'settleCoin': 'USDT',
    }, auth=True)
    return result.get('list', [])

def get_wallet_balance() -> float:
    """Available USDT equity in Unified Trading Account."""
    try:
        result   = bybit_get('/v5/account/wallet-balance', {
            'accountType': 'UNIFIED',
            'coin':        'USDT',
        }, auth=True)
        accounts = result.get('list', [])
        if accounts:
            for c in accounts[0].get('coin', []):
                if c['coin'] == 'USDT':
                    return float(c.get('availableToWithdraw', 0))
    except Exception:
        pass
    return 0.0

