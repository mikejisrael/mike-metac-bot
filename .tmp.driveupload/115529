# ─── Bybit V5 API helpers ──────────────────────────────────────────────────────

def _sign(data_str: str):
    """Return (timestamp_ms, hex_signature) for Bybit V5 auth."""
    ts  = str(int(time.time() * 1000))
    msg = ts + BYBIT_API_KEY + RECV_WINDOW + data_str
    sig = hmac.new(BYBIT_API_SECRET.encode(), msg.encode(), hashlib.sha256).hexdigest()
    return ts, sig

def _auth_headers(data_str: str) -> dict:
    ts, sig = _sign(data_str)
    return {
        'X-BAPI-API-KEY':     BYBIT_API_KEY,
        'X-BAPI-TIMESTAMP':   ts,
        'X-BAPI-SIGN':        sig,
        'X-BAPI-RECV-WINDOW': RECV_WINDOW,
    }

def bybit_get(endpoint: str, params: dict = None, auth: bool = False,
              base_url: str = None) -> dict:
    """
    GET request to Bybit V5. Returns result dict or raises on error.
    Public market data calls use MARKET_URL (live API — real prices).
    Authenticated account/order calls use TRADING_URL (testnet or live).
    """
    params = params or {}
    query  = urlencode(params)
    root   = base_url or (TRADING_URL if auth else MARKET_URL)
    url    = f'{root}{endpoint}?{query}' if query else f'{root}{endpoint}'
    hdrs   = _auth_headers(query) if auth else {}
    r = requests.get(url, headers=hdrs, timeout=15)
    r.raise_for_status()
    data = r.json()
    if data.get('retCode') != 0:
        raise ValueError(f"Bybit {data.get('retCode')}: {data.get('retMsg')}")
    return data['result']

def bybit_post(endpoint: str, body: dict) -> dict:
    """POST request to Bybit V5 (always authenticated, always TRADING_URL)."""
    body_str = json.dumps(body)
    hdrs = _auth_headers(body_str)
    hdrs['Content-Type'] = 'application/json'
    r = requests.post(f'{TRADING_URL}{endpoint}', data=body_str, headers=hdrs, timeout=15)
    r.raise_for_status()
    data = r.json()
    if data.get('retCode') != 0:
        raise ValueError(f"Bybit {data.get('retCode')}: {data.get('retMsg')}")
    return data['result']

# ─── Instrument info cache (qty precision per coin) ────────────────────────────
_instrument_cache: dict = {}

def get_instrument_info(symbol: str) -> dict:
    """Fetch and cache lot size / tick size for a symbol."""
    if symbol not in _instrument_cache:
        try:
            result = bybit_get('/v5/market/instruments-info', {
                'category': 'linear',
                'symbol':   symbol,
            })
            items = result.get('list', [])
            if items:
                lot = items[0].get('lotSizeFilter', {})
                _instrument_cache[symbol] = {
                    'qty_step':    float(lot.get('qtyStep', 0.001)),
                    'min_qty':     float(lot.get('minOrderQty', 0.001)),
                    'price_scale': int(items[0].get('priceScale', 2)),
                }
            else:
                _instrument_cache[symbol] = {'qty_step': 0.001, 'min_qty': 0.001, 'price_scale': 2}
        except Exception:
            _instrument_cache[symbol] = {'qty_step': 0.001, 'min_qty': 0.001, 'price_scale': 2}
    return _instrument_cache[symbol]

def round_qty(symbol: str, raw_qty: float) -> float:
    """Round quantity to the exchange's required step size."""
    info = get_instrument_info(symbol)
    step = info['qty_step']
    qty  = math.floor(raw_qty / step) * step
    # Format to avoid floating-point noise
    decimals = len(str(step).rstrip('0').split('.')[-1]) if '.' in str(step) else 0
    qty = round(qty, decimals)
    return max(qty, info['min_qty'])

def round_price(symbol: str, price: float) -> float:
    """Round price to the exchange's tick size."""
    info = get_instrument_info(symbol)
    return round(price, info['price_scale'])

# ─── Market data ───────────────────────────────────────────────────────────────

def get_klines(symbol: str) -> list:
    """
    Fetch 4h OHLCV candles. Returns list newest-last.
    Each item: [timestamp, open, high, low, close, volume, turnover]
    """
    result  = bybit_get('/v5/market/kline', {
        'category': 'linear',
        'symbol':   symbol,
        'interval': CANDLE_INTERVAL,
        'limit':    str(CANDLES_TO_FETCH),
    })
    candles = result.get('list', [])
    candles.reverse()          # Bybit returns newest-first; reverse to chronological
    return candles

def get_ticker(symbol: str) -> dict:
    """Current ticker: last price, funding rate, 24h high/low, volume."""
    result = bybit_get('/v5/market/tickers', {
        'category': 'linear',
        'symbol':   symbol,
    })
    items = result.get('list', [])
    return items[0] if items else {}

def get_open_interest(symbol: str) -> list:
    """Open interest for the last two 4h periods (newest first)."""
    result = bybit_get('/v5/market/open-interest', {
        'category':     'linear',
        'symbol':       symbol,
        'intervalTime': '4h',
        'limit':        '2',
    })
    return result.get('list', [])

def get_fear_greed() -> tuple:
