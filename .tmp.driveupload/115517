@echo off
:: ─── IBKR Claude Bot Runner ───────────────────────────────────────────────────
:: Called by Windows Task Scheduler twice daily.
:: Activates the virtual environment and runs the bot.
:: Output is appended to a dated log file in ibkr_logs\scheduler\

set PROJECT_DIR=C:\Users\mikej\metac-bot-template
set VENV_ACTIVATE=%PROJECT_DIR%\venv312\Scripts\activate.bat
set BOT_SCRIPT=%PROJECT_DIR%\ibkr_claude_bot.py
set LOG_DIR=%PROJECT_DIR%\ibkr_logs\scheduler

:: Create scheduler log directory if it doesn't exist
if not exist "%LOG_DIR%" mkdir "%LOG_DIR%"

:: Build a timestamped log filename (one file per day)
for /f "tokens=1-3 delims=-" %%a in ("%DATE:~10,4%-%DATE:~4,2%-%DATE:~7,2%") do (
    set LOG_FILE=%LOG_DIR%\bot_run_%%a-%%b-%%c.log
)

:: Fallback: use a fixed filename if date parsing fails
if "%LOG_FILE%"=="" set LOG_FILE=%LOG_DIR%\bot_run.log

echo ============================================================ >> "%LOG_FILE%"
echo Run started: %DATE% %TIME% >> "%LOG_FILE%"
echo ============================================================ >> "%LOG_FILE%"

:: Change to project directory and run
cd /d "%PROJECT_DIR%"
call "%VENV_ACTIVATE%"
python "%BOT_SCRIPT%" >> "%LOG_FILE%" 2>&1

echo ============================================================ >> "%LOG_FILE%"
echo Run finished: %DATE% %TIME% >> "%LOG_FILE%"
echo ============================================================ >> "%LOG_FILE%"