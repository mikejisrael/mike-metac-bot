    print(f"  Saved to {results_file}")


def _latest_centers(agg_bucket) -> list | None:
    """Given one aggregation bucket (e.g. aggregations['recency_weighted']),
    return its centers list — preferring the 'latest' snapshot, falling back
    to the most recent entry in 'history' when 'latest' is null. Confirmed in
    practice: Metaculus doesn't always keep 'latest' populated even when the
    community prediction is known and shown elsewhere (e.g. email alerts)."""
    if not isinstance(agg_bucket, dict):
        return None
    latest = agg_bucket.get("latest")
    if isinstance(latest, dict):
        centers = latest.get("centers")
        if isinstance(centers, list) and centers:
            return centers
    history = agg_bucket.get("history")
    if isinstance(history, list) and history:
        last_entry = history[-1]
        if isinstance(last_entry, dict):
            centers = last_entry.get("centers")
            if isinstance(centers, list) and centers:
                return centers
    return None


def _safe_dig(d, *keys):
    """Walk a chain of dict keys, returning None the moment anything along
    the way isn't a dict — including when a key is PRESENT but explicitly
    null (Metaculus does this, e.g. "latest": null rather than omitting the
    key), which plain chained .get() calls don't protect against: .get()
    only supplies a default for a MISSING key, not a present-but-None one,
    so the next .get() in the chain throws AttributeError on None."""
    for k in keys:
        if not isinstance(d, dict):
            return None
        d = d.get(k)
    return d


def fetch_live_forecast_context(
    post_id: int, expected_title: str, options: list[str] | None = None
) -> tuple[float | dict[str, float] | None, str | None, float | dict[str, float] | None]:
    """Direct GET against the legacy api2 detail endpoint (matched by POST id
    — see module docstring), authenticated as ACTIVE_TOKEN (the bot, as of
    2026-07-03 — see module docstring for why this changed from the
    personal account), to pull two things get_question_by_post_id doesn't
    reliably surface: the account's own last forecast on this question, and
    the current community prediction. Parsed independently via _safe_dig
    (not chained .get()/bracket access) so a present-but-null value anywhere
    in either chain can't throw and take the other one down with it.

    RENAMED (2026-07-03) from fetch_live_personal_context — same function,
    now generic to whichever account ACTIVE_TOKEN points at.

    options: pass question.options for a MultipleChoiceQuestion to get back
    dicts (option label -> probability) instead of single floats. Centers
    are matched to options POSITIONALLY (assumes the API returns them in
    question.options order) — this is an assumption, not a confirmed
    guarantee; call sites should sanity-check the printed debug output
    against the real question before trusting an MC result here."""
    if not ACTIVE_TOKEN:
        return None, None, None
    try:
        url = f"https://www.metaculus.com/api2/questions/{post_id}/"
        resp = requests.get(
            url, headers={"Authorization": f"Token {ACTIVE_TOKEN}"}, timeout=20
        )
        if resp.status_code != 200:
            print(f"    (live forecast-context fetch: HTTP {resp.status_code})")
            return None, None, None
        data = resp.json()
        if not isinstance(data, dict):
            print(f"    (live forecast-context fetch: unexpected response shape "
                  f"{type(data).__name__}, raw: {resp.text[:200]!r})")
            return None, None, None

        fetched_title = data.get("title") or _safe_dig(data, "question", "title") or ""
        if expected_title and not titles_match(expected_title, fetched_title):
            print(f"    ⚠️  api2 lookup for post {post_id} returned a different title — "
                  f"skipping live forecast-context (proceeding without it).")
            print(f"       Expected: {expected_title[:90]}")
            print(f"       Got:      {fetched_title[:90]}")
            return None, None, None

        my_prob = my_ts = None
        history = _safe_dig(data, "question", "my_forecasts", "history")
        if history:
            latest = history[-1] if isinstance(history, list) else None
            if isinstance(latest, dict):
                values = latest.get("forecast_values")
                if isinstance(values, list):
                    if options and len(values) == len(options):
                        my_prob = dict(zip(options, values))
                    elif not options and len(values) > 1:
                        my_prob = values[1]
                start_time = latest.get("start_time")
                if start_time is not None:
                    try:
                        my_ts = datetime.fromtimestamp(start_time, tz=timezone.utc).isoformat()
                    except (TypeError, ValueError, OSError):
                        pass

        cp = None
        rw_bucket = _safe_dig(data, "question", "aggregations", "recency_weighted")
        centers = _latest_centers(rw_bucket)
        if not centers:
            uw_bucket = _safe_dig(data, "question", "aggregations", "unweighted")
            centers = _latest_centers(uw_bucket)
        if centers:
            if options and len(centers) == len(options):
                cp = dict(zip(options, centers))
            elif not options:
                cp = centers[1] if len(centers) > 1 else centers[0]
            # else: options given but length mismatch — cp stays None rather
            # than guessing a positional mapping we can't trust.

        # Note: recency_weighted (and unweighted) sometimes comes back fully
        # null across history/latest/score_data/movement for a given
        # question via this endpoint — confirmed in practice, not a parsing
        # bug. When that happens cp is genuinely unavailable; the prompt
        # just proceeds without community-prediction context.

        return my_prob, my_ts, cp
    except Exception as e:
        print(f"    (live forecast-context fetch failed: {e})")
        return None, None, None


def run_single():
    """python meta_refresh_forecast.py --single
    Prompts for a Metaculus URL or post ID, fetches it via the post-id-based
    get_question_by_post_id AS THE BOT ACCOUNT (mike_iz_-bot — CHANGED
    2026-07-03, see module docstring), shows the bot's last forecast on
    this question next to the current community prediction, gets a fresh
    forecast from Claude synchronously, confirms, then submits. Supports
    both BinaryQuestion and MultipleChoiceQuestion (MC added 2026-07-03)."""
    if single_client is None:
        print("  ❌ No Metaculus token available (METAC_TOURNAMENT_TOKEN / "
              "METACULUS_TOKEN both unset in .env).")
        return

    print("Auth: --single acts as mike_iz_-bot via ACTIVE_TOKEN "
          "(METAC_TOURNAMENT_TOKEN, falling back to METACULUS_TOKEN) — "
          "same account as every other path in this file.")

    raw = input("Paste the Metaculus question URL or post ID: ").strip()
    post_id = parse_post_id(raw)
    if post_id is None:
        print(f"Could not find a post ID in '{raw}'. Paste the full URL or just the numeric ID.")
        return

    print(f"Fetching post {post_id} from Metaculus (as mike_iz_-bot)...")
    try:
        result = single_client.get_question_by_post_id(post_id)
    except Exception as e:
        print(f"  ❌ Could not fetch post {post_id}: {e}")
        return

    question = result[0] if isinstance(result, list) else result
    if not isinstance(question, (BinaryQuestion, MultipleChoiceQuestion)):
        print(f"  ⚠️  Post {post_id} is not a binary or multiple-choice question "
              f"({type(question).__name__}). --single currently only supports "
              f"binary and multiple-choice questions.")
        return
    if not _is_open_for_forecasting(question):
        print(f"  ⚠️  Q{getattr(question, 'id_of_question', '?')}: state="
              f"{getattr(question, 'state', None)}, not open for forecasting — "
              f"stopping before asking Claude for a forecast.")
        return
    if isinstance(question, BinaryQuestion):
        _run_single_binary(question, post_id)
    else:
        _run_single_mc(question, post_id)


# ─── CP-divergence + weak-grounding safety check ──────────────────────────────
def _mc_distance(dist_a: dict, dist_b: dict) -> float:
    """Total variation distance between two option->probability dicts —
    half the sum of absolute differences across all options that appear in
    either dict (treating a missing option as 0 probability). Standard
    metric for comparing two probability distributions over the same
    outcome space; ranges 0 (identical) to 1 (disjoint support)."""
    options = set(dist_a) | set(dist_b)
    return sum(abs(dist_a.get(o, 0.0) - dist_b.get(o, 0.0)) for o in options) / 2


def check_cp_divergence(original, new, cp, is_mc: bool = False) -> bool | None:
    """Added 2026-07-15 (Mike's request, after a --single refresh moved
    FURTHER from CP than the prior forecast with no research grounding
    found — suspected the bot was missing real news). Returns True if the
    new forecast moved further from CP than the original did, False if it
    moved closer or CP was unchanged-relative-to, None if we can't tell
    (missing original, new, or CP).

    Deliberately NOT "any divergence from CP is suspicious" — the bot is
    SUPPOSED to be able to disagree with the crowd when it has good reason
    to; a blanket rule would suppress legitimate, well-grounded
    disagreement along with the bad kind. This only measures directional
    MOVEMENT (did the gap widen), and is only actually acted on in
    combination with weak/absent research grounding — see the call sites
    in _run_single_binary/_run_single_mc for where the two signals combine."""
    if original is None or new is None or cp is None:
        return None
    if is_mc:
        old_gap = _mc_distance(original, cp)
        new_gap = _mc_distance(new, cp)
    else:
        old_gap = abs(original - cp)
        new_gap = abs(new - cp)
    return new_gap > old_gap


def prompt_manual_cp(is_mc: bool = False, options: list[str] | None = None):
    """Added 2026-07-15 (Mike's follow-up request): community prediction is
    often withheld at the API level for bot-flagged accounts — this may not
    be a rare edge case for mike_iz_-bot, possibly the COMMON case — but
    Mike can often still see it directly on the site. Prompts for a manual
    entry when the API returned none, so check_cp_divergence has a real
    chance to run instead of silently no-op'ing on every question where CP
    happens to be hidden. Only ever called from the interactive --single
    path (_run_single_binary/_run_single_mc) — never from the unattended
    --submit/--check batch path, where an input() call would hang a
    scheduled run forever.

    Returns the entered value (float for binary, dict for MC) or None if
    skipped (blank input at any point — a partial MC entry is treated as
    fully skipped rather than saving a half-entered distribution)."""
    print("  Community prediction not available via API.")
    if is_mc:
        first = input("  Can you see it on the site? Enter the first option's value, "
                       "or press Enter to skip entirely: ").strip().rstrip("%")
        if not first:
            return None
        cp = {}
        for i, opt in enumerate(options):
            raw = first if i == 0 else input(f"    {opt}: ").strip().rstrip("%")
            if not raw:
                return None
            try:
                cp[opt] = float(raw) / 100
            except ValueError:
                print("    Not a number — skipping manual CP entry entirely.")
                return None
        total = sum(cp.values())
        if abs(total - 1.0) > 0.02:
            print(f"  ⚠️  Entered values sum to {total:.0%}, not 100% — normalizing proportionally.")
            cp = {k: v / total for k, v in cp.items()}
        return cp
    else:
        raw = input("  Can you see it on the site? Enter it now (0-100), "
                     "or press Enter to skip: ").strip().rstrip("%")
        if not raw:
            return None
        try:
            val = float(raw) / 100
            if 0 <= val <= 1:
                return val
            print("  Must be between 0 and 100 — skipping manual CP entry.")
            return None
        except ValueError:
            print("  Not a number — skipping manual CP entry.")
            return None


def prompt_review_and_confirm(
    original, new, cp, is_mc: bool = False, show_warning: bool = False
):
    """CHANGED (2026-07-14, Mike's follow-up): originally only ran when the
    CP-divergence flag fired. Mike's actual want, after seeing a real run
    land suspiciously exactly on a manually-entered CP (99%) with reasoning
    that — on inspection — hadn't actually confirmed a qualifying event
    happened, just assumed one probably had: the option to manually enter
    a value should be available on EVERY submission, not gated behind the
    divergence check specifically. "Respects CP but leaves a little wiggle
    room" (his words) is a legitimate human judgment call the check alone
    can't make for him. So this now ALWAYS runs as the final step before
    submission; show_warning controls only whether the CP-divergence
    banner is printed first — the underlying accept/override/cancel choice
    is offered either way.

    Returns (decision, override_value):
      decision: "submit_as_is" | "cancelled" | "manual_override"
      override_value: the human-entered value if decision == "manual_override", else None"""
    if show_warning:
        print(f"\n  {'⚠️ '*20}")
        print("  WARNING: this forecast moved FURTHER from the community prediction")
        print("  than the prior forecast did, AND no live data or research grounding")
        print("  was found for this question. The bot may be missing relevant news —")
        print("  worth checking the question on the site yourself before trusting this.")
        print(f"  {'⚠️ '*20}\n")

    if is_mc:
        if original is not None:
            print(f"  Prior forecast:  {original}")
        print(f"  New forecast:    {new}")
        if cp is not None:
            print(f"  Community pred.: {cp}")
    else:
        if original is not None:
            print(f"  Prior forecast:  {_format_pct(original)}")
        print(f"  New forecast:    {_format_pct(new)}")
        if cp is not None:
            print(f"  Community pred.: {_format_pct(cp)}")

    choice = input(
        "\n  [Y]es, submit as-is / [n]o, cancel / [m]anually enter a value: "
    ).strip().lower()

    if choice == "m":
        if is_mc:
            print("  Enter a probability (0-100) for each option:")
            override = {}
            for opt in new.keys():
                while True:
                    raw = input(f"    {opt}: ").strip().rstrip("%")
                    try:
                        override[opt] = float(raw) / 100
                        break
                    except ValueError:
                        print("    Not a number — try again.")
            total = sum(override.values())
            if abs(total - 1.0) > 0.02:
                print(f"  ⚠️  Entered values sum to {total:.0%}, not 100% — normalizing proportionally.")
                override = {k: v / total for k, v in override.items()}
            return "manual_override", override
        else:
            while True:
                raw = input("  Enter a probability (0-100): ").strip().rstrip("%")
                try:
                    val = float(raw) / 100
                    if 0 <= val <= 1:
                        return "manual_override", val
                    print("  Must be between 0 and 100 — try again.")
                except ValueError:
                    print("  Not a number — try again.")
    elif choice == "n":
        return "cancelled", None
    else:
        return "submit_as_is", None


def _format_pct(value) -> str:
    """Format a probability as a percentage string, with extra precision
    when the value is close enough to 0% or 100% that standard whole-
    percent rounding would be misleading. Added 2026-07-14 after a real
    --single run: Mike entered a manual CP of 0.5%, correctly stored and
    used in the divergence math throughout, but every DISPLAY of it showed
    "0%" — indistinguishable from a genuine, literal zero. The stored
    value and any downstream math were never wrong, this was purely a
    print-formatting gap. Scoped to the --single interactive display path
    (community prediction / prior / new forecast lines) — not applied to
    the LLM-prompt-building text or the batch/dry-run summary paths,
    which weren't the reported issue and are a separate, larger change if
    ever wanted."""
    if value is None:
        return "N/A"
    pct = value * 100
    if 0 < pct < 1 or 99 < pct < 100:
        return f"{pct:.1f}%"
    return f"{value:.0%}"


