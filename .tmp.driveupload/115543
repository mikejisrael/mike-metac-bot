"""
repair_resolve_times.py — one-off repair.

Run from C:\\Users\\mikej\\metac-bot-template with venv312 active:

    python repair_resolve_times.py

Problem: batch_jobs_refresh_20260621_1943.json has 8 entries whose
resolve_time was corrupted to a placeholder ("2028-01-01T13:00:00+00:00",
or similar implausibly-far-future values) by the bug in submit_refresh_batch
fixed in meta_refresh_forecast.py. Because that file's entries are the most
recent per question_id, they win the dedup in find_questions_to_refresh and
hide these 8 questions from the closing-soon list entirely — so re-running
--submit can never reach them to fix them naturally.

This script:
  1. Scans every batch_jobs*.json file for resolve_time values that look
     like the placeholder (year >= 2027 — implausibly far out compared to
     everything else in your active batches).
  2. For each affected question_id, searches all OTHER batch_jobs*.json
     files for a valid (non-placeholder) resolve_time for that same
     question_id.
  3. Shows you a before/after diff and asks for confirmation.
  4. Only on "y" does it back up the affected file (.bak) and write the fix.

Nothing is modified until you confirm.
"""

import json
import glob
import os
import shutil
from datetime import datetime, timezone

BATCH_DIR = "Meta batches"
PLACEHOLDER_YEAR_CUTOFF = 2027  # anything resolving on/after this is suspect


def is_suspect(resolve_time_str):
    if not resolve_time_str:
        return False
    try:
        dt = datetime.fromisoformat(resolve_time_str.replace("Z", "+00:00"))
        return dt.year >= PLACEHOLDER_YEAR_CUTOFF
    except Exception:
        return False


def main():
    job_files = sorted(
        glob.glob(os.path.join(BATCH_DIR, "batch_jobs_2*.json")) +
        glob.glob(os.path.join(BATCH_DIR, "batch_jobs_refresh_*.json"))
    )

    # question_id -> list of (job_file, custom_id, resolve_time_str)
    by_question = {}
    for jf in job_files:
        with open(jf) as f:
            data = json.load(f)
        question_ids = data.get("question_ids", {})
        resolve_times = data.get("resolve_times", {})
        for custom_id, q_id in question_ids.items():
            rt = resolve_times.get(custom_id)
            by_question.setdefault(q_id, []).append((jf, custom_id, rt))

    fixes = []  # (job_file, custom_id, q_id, old_rt, new_rt)
    for q_id, entries in by_question.items():
        for jf, custom_id, rt in entries:
            if is_suspect(rt):
                # look for a good value elsewhere for this question_id
                good = None
                for other_jf, other_cid, other_rt in entries:
                    if other_cid != custom_id and other_rt and not is_suspect(other_rt):
                        good = other_rt
                        break
                if good:
                    fixes.append((jf, custom_id, q_id, rt, good))

    if not fixes:
        print("No suspect resolve_time values found needing repair.")
        return

    print(f"Found {len(fixes)} entries to fix:\n")
    for jf, custom_id, q_id, old_rt, new_rt in fixes:
        print(f"  {jf}")
        print(f"    custom_id={custom_id}  question_id={q_id}")
        print(f"    OLD resolve_time = {old_rt!r}")
        print(f"    NEW resolve_time = {new_rt!r}\n")

    confirm = input("Apply these fixes? [y/N]: ").strip().lower()
    if confirm != "y":
        print("Cancelled — nothing changed.")
        return

    # group fixes by file so we only open/write each file once
    fixes_by_file = {}
    for jf, custom_id, q_id, old_rt, new_rt in fixes:
        fixes_by_file.setdefault(jf, []).append((custom_id, new_rt))

    for jf, entries in fixes_by_file.items():
        backup = jf + ".bak"
        shutil.copy2(jf, backup)
        with open(jf) as f:
            data = json.load(f)
        for custom_id, new_rt in entries:
            data["resolve_times"][custom_id] = new_rt
        with open(jf, "w") as f:
            json.dump(data, f, indent=2)
        print(f"✅ Patched {jf} (backup saved to {backup})")


if __name__ == "__main__":
    main()