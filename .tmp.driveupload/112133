"""
resubmit_q44150.py — One-off correction for the "foreign visitors to the US
in June 2026" tournament question.

IMPORTANT: there are two conflicting IDs floating around for this question —
44150 (from the original terminal log / batch_results JSON) and 44128 (from
the URL you opened on Metaculus). Same title, different ID. Rather than
guess which one is live, this script looks the question up by TITLE among
currently-open tournament posts (using the same titles_match guard the
other scripts use) and shows you exactly what it finds — including the ID —
before submitting anything. You confirm before it submits.

The original submission was built from a malformed CDF (the comma-parsing
bug — "4,500,000" was silently read as 0 — now fixed in
tournament_forecast.py's parse_numeric_response). This script re-forecasts
and re-submits that question through the corrected pipeline.

Usage:
  python resubmit_q44150.py

Run this from the same folder as tournament_forecast.py and
meta_question_matching.py.
"""

import os
import requests
from dotenv import load_dotenv
load_dotenv()

from forecasting_tools import NumericQuestion
import tournament_forecast as tf
from meta_question_matching import titles_match

TARGET_TITLE = "How many foreign visitors will fly to the United States in June 2026?"


def find_matching_posts(target_title: str) -> list[dict]:
    """Search currently-open tournament posts for anything whose title
    matches target_title, returning ALL matches (there may be more than
    one if Metaculus genuinely has two question objects with the same
    title — that's possible and we want to surface it, not hide it)."""
    headers = {"Authorization": f"Token {os.getenv('METACULUS_TOKEN')}"}
    r = requests.get(
        f"https://www.metaculus.com/api/posts/?tournaments={tf.TOURNAMENT_ID}&limit=100",
        headers=headers, timeout=30
    )
    r.raise_for_status()
    posts = r.json().get("results", [])

    matches = []
    for post in posts:
        q = post.get("question") or {}
        title = q.get("title") or post.get("title") or ""
        if titles_match(target_title, title):
            matches.append(post)
    return matches


def main():
    print(f"Searching open tournament {tf.TOURNAMENT_ID} posts for:")
    print(f'  "{TARGET_TITLE}"\n')

    matches = find_matching_posts(TARGET_TITLE)

    if not matches:
        print("❌ No open question with a matching title found.")
        print("   It may have closed since you checked — verify on Metaculus before re-running.")
        return

    if len(matches) > 1:
        print(f"⚠️  Found {len(matches)} open questions with matching titles — that's unexpected:")
        for post in matches:
            q = post.get("question") or {}
            print(f"     ID {q.get('id')}: {q.get('title')}")
        print("\nStopping here — figure out which one is the real target before resubmitting "
              "(if these are genuinely two different questions, only one should get this correction).")
        return

    post = matches[0]
    q = post.get("question") or {}
    question_id = q.get("id")
    print(f"Found exactly one match: Q{question_id}")
    print(f"  Title:  {q.get('title')}")
    print(f"  Bounds: {q.get('scaling', {}).get('range_min')} to {q.get('scaling', {}).get('range_max')}")

    confirm = input(f"\nSubmit a corrected forecast to Q{question_id}? [y/N]: ").strip().lower()
    if confirm != "y":
        print("Aborted — nothing submitted.")
        return

    question = NumericQuestion.from_metaculus_api_json(post)

    print("\nRe-forecasting with the corrected parser...")
    q_type, forecast = tf.forecast_question(question)

    if forecast is None:
        print("\n❌ Forecast failed or was rejected by the sanity check — nothing submitted.")
        print("   See the warning above for the reason.")
        return

    print("\nSubmitting corrected prediction to Metaculus...")
    ok = tf.submit_forecast(question, q_type, forecast)
    if ok:
        print(f"\n✅ Done — check https://www.metaculus.com/questions/{question_id}/ to confirm "
              f"the displayed prediction now sits inside the visible range.")
    else:
        print("\n❌ Submission failed — see error above.")


if __name__ == "__main__":
    main()