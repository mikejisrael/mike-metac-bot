"""
meta_test.py — read-only sanity/audit tool for the Metaculus forecasting
pipeline. Does NOT submit, forecast, or write anything to Metaculus —
every check here is GET-only, safe to run any time, as often as you like.

Purpose: answer the actual question with evidence, not code review —
"is every script recalling and recording the right question, under the
right ID, with the right prediction?" — checked against local history
these scripts have already produced, AND against Metaculus live right now.

Usage:
  python meta_test.py            # run everything, print a pass/fail summary
  python meta_test.py --history  # only audit local saved forecast history
  python meta_test.py --live     # only audit current live tournament data
  python meta_test.py --quiet    # suppress per-question detail, summary only

Checks:
  A. History title-match audit — every "success" entry in every
     batch_results*.json (both Meta batches/ and tournament_batches/) is
     re-fetched live by its stored question_id via the proven
     api2/questions/?ids= endpoint, and the live title is compared against
     the title stored at forecast time. A mismatch here means a script
     submitted (or is now misremembering) a forecast against the wrong
     question.
  B. post_id coverage — reports what fraction of local history has a
     post_id on file (added 2026-06-29). Entries without one predate the
     fix and are skipped by meta_refresh_forecast.py rather than guessed
     at, by design — not itself a failure.
  C. Live tournament consistency — for every CURRENTLY OPEN question across
     all configured tournaments, confirms the title returned by the listing
     endpoint (api/posts/) matches the title returned by the detail
     endpoint (api2/questions/?ids=) for that same question_id. This is the
     live version of Check A — it proves tournament_forecast.py's actual
     current question set resolves correctly, right now.
  D. Refresh post_id live fetch — samples up to 10 history entries that DO
     have a post_id on file, fetches each one live via
     MetaculusClient.get_question_by_post_id (the exact method
     meta_refresh_forecast.py's fixed fetch_question_by_id now uses), and
     confirms the title matches. This is the live proof that yesterday's
     fix actually works, not just that the code reads correctly.
"""

import os
import sys
import glob
import json
import time
import requests
from datetime import datetime, timezone
from dotenv import load_dotenv

load_dotenv()

from meta_question_matching import titles_match

TOKEN = os.getenv("METAC_TOURNAMENT_TOKEN") or os.getenv("METACULUS_TOKEN")
HEADERS = {"Authorization": f"Token {TOKEN}"}

HISTORY_DIRS = ["Meta batches", "tournament_batches"]
CHUNK_SIZE = 10
SLEEP_BETWEEN_CALLS = 1.2


# ─────────────────────────────────────────────────────────────────────────
# Shared result tracking
# ─────────────────────────────────────────────────────────────────────────
class Report:
    def __init__(self):
        self.checks = []  # (name, passed: bool, detail: str)

    def add(self, name, passed, detail=""):
        self.checks.append((name, passed, detail))

    def print_summary(self) -> bool:
        print("\n" + "=" * 60)
        print("SUMMARY")
        print("=" * 60)
        n_pass = sum(1 for _, p, _ in self.checks if p)
        n_fail = len(self.checks) - n_pass
        for name, passed, detail in self.checks:
            mark = "✅" if passed else "❌"
            print(f"  {mark} {name}" + (f" — {detail}" if detail else ""))
        print("-" * 60)
        print(f"{n_pass} passed, {n_fail} failed")
        if n_fail:
            print("\n⚠️  At least one check failed — do NOT trust submissions "
                  "from the affected script(s) until investigated.")
        return n_fail == 0


# ─────────────────────────────────────────────────────────────────────────
# Helpers
# ─────────────────────────────────────────────────────────────────────────
def load_history_entries() -> list[dict]:
    """Collect every (question_id, post_id, question_text, source_file)
    record from every batch_results*.json under HISTORY_DIRS. post_id is
    None for entries saved before the post_id fix (2026-06-29)."""
    entries = []
    for d in HISTORY_DIRS:
        for rf in glob.glob(os.path.join(d, "batch_results*.json")):
            try:
                with open(rf) as f:
                    data = json.load(f)
            except Exception as e:
                print(f"  ⚠️  Could not read {rf}: {e}")
                continue
            for r in data.values():
                qid = r.get("question_id")
                if qid is None:
                    continue
                entries.append({
                    "question_id":   qid,
                    "post_id":       r.get("post_id"),
                    "question_text": r.get("question_text", ""),
                    "source_file":   rf,
                    "status":        r.get("status"),
                })
    return entries


def fetch_titles_by_question_id(question_ids: list) -> dict:
    """Chunked fetch via the proven api2/questions/?ids= endpoint. Returns
    {question_id: live_title}. Matches by the ID actually present in each
    returned item — never assumes response order matches request order
    (this is the exact bug class we're trying to catch elsewhere)."""
    titles = {}
    unique_ids = sorted(set(question_ids))
    for i in range(0, len(unique_ids), CHUNK_SIZE):
        chunk = unique_ids[i:i + CHUNK_SIZE]
        ids_str = ",".join(str(q) for q in chunk)
        url = f"https://www.metaculus.com/api2/questions/?ids={ids_str}&limit={CHUNK_SIZE}"
        try:
            time.sleep(SLEEP_BETWEEN_CALLS)
            r = requests.get(url, headers=HEADERS, timeout=20)
            if r.status_code != 200:
                print(f"  ⚠️  HTTP {r.status_code} fetching chunk {chunk}")
                continue
            data = r.json()
            for item in data.get("results", []):
                q = item.get("question") or item
                qid = q.get("id") or item.get("id")
                title = q.get("title") or item.get("title") or ""
                if qid is not None:
                    titles[qid] = title
        except Exception as e:
            print(f"  ⚠️  Chunk fetch error: {e}")
    return titles


# ─────────────────────────────────────────────────────────────────────────
# CHECK A — title-match audit of all local history (question_id path)
# ─────────────────────────────────────────────────────────────────────────
def check_history_title_match(report: Report, quiet: bool):
    print("\n" + "-" * 60)
    print("CHECK A: do stored question_ids still resolve to the same title?")
    print("-" * 60)

    entries = load_history_entries()
    if not entries:
        report.add("History title-match audit", True, "no history found — nothing to check")
        return

    successful = [e for e in entries if e.get("status") == "success"]
    print(f"  {len(entries)} total history entries, {len(successful)} marked 'success'")

    question_ids = [e["question_id"] for e in successful]
    live_titles = fetch_titles_by_question_id(question_ids)

    mismatches = []
    not_found = []
    for e in successful:
        qid = e["question_id"]
        live_title = live_titles.get(qid)
        if live_title is None:
            not_found.append(e)
            continue
        if not titles_match(e["question_text"], live_title):
            mismatches.append((e, live_title))

    if not quiet:
        for e, live_title in mismatches:
            print(f"  🛑 MISMATCH Q{e['question_id']} (from {os.path.basename(e['source_file'])}):")
            print(f"       Stored: {e['question_text'][:80]}")
            print(f"       Live:   {live_title[:80]}")
        for e in not_found[:20]:
            print(f"  ℹ️  Q{e['question_id']}: not returned by ?ids= fetch "
                  f"(may be a resolved/archived question outside this endpoint's "
                  f"normal range, or a real recycled/bad ID — worth a manual look "
                  f"if this list is long)")
        if len(not_found) > 20:
            print(f"  ... and {len(not_found) - 20} more not-found")

    report.add(
        "History title-match audit (question_id)",
        len(mismatches) == 0,
        f"{len(mismatches)} mismatch(es), {len(not_found)} not found, "
        f"out of {len(successful)} checked"
    )


# ─────────────────────────────────────────────────────────────────────────
# CHECK B — post_id coverage and distinctness
# ─────────────────────────────────────────────────────────────────────────
def check_post_id_coverage(report: Report, quiet: bool):
    print("\n" + "-" * 60)
    print("CHECK B: post_id coverage (needed for meta_refresh_forecast.py to work)")
    print("-" * 60)

    entries = load_history_entries()
    if not entries:
        report.add("post_id coverage", True, "no history found — nothing to check")
        return

    with_post_id = [e for e in entries if e.get("post_id") is not None]
    without = [e for e in entries if e.get("post_id") is None]
    same_value = [e for e in with_post_id if e["post_id"] == e["question_id"]]

    print(f"  {len(with_post_id)}/{len(entries)} entries have post_id on file")
    print(f"  {len(without)} entries predate the fix — these will be SKIPPED by "
          f"meta_refresh_forecast.py rather than guessed at")
    if same_value and not quiet:
        print(f"  ℹ️  {len(same_value)} entries where post_id == question_id "
              f"(possible for some questions — not itself an error, just flagging "
              f"it since it's the one case where a real ID-crossing bug would be "
              f"invisible in this audit)")

    # Missing post_id on entries that predate the fix is expected and
    # handled gracefully (skipped, not guessed) — not a failure by itself.
    report.add(
        "post_id coverage",
        True,
        f"{len(with_post_id)}/{len(entries)} have post_id "
        f"({len(without)} pre-fix entries will be skipped by refresh, not mismatched)"
    )


# ─────────────────────────────────────────────────────────────────────────
# CHECK C — live tournament listing resolves correctly right now
# ─────────────────────────────────────────────────────────────────────────
def check_live_tournament_consistency(report: Report, quiet: bool):
    print("\n" + "-" * 60)
    print("CHECK C: do CURRENTLY OPEN tournament questions resolve consistently "
          "between the listing endpoint and the detail endpoint?")
    print("-" * 60)

    try:
        import meta_batch_forecast as bf
    except Exception as e:
        report.add("Live tournament consistency", False, f"could not import meta_batch_forecast.py: {e}")
        return

    tournaments = bf.ALLOWED_TOURNAMENTS
    listing_by_qid = {}  # question_id -> title (from listing endpoint)

    for tid in tournaments:
        url = f"https://www.metaculus.com/api/posts/?tournaments={tid}&limit=100"
        try:
            time.sleep(SLEEP_BETWEEN_CALLS)
            r = requests.get(url, headers=HEADERS, timeout=30)
            if r.status_code != 200:
                print(f"  ⚠️  Tournament {tid}: HTTP {r.status_code}")
                continue
            posts = r.json().get("results", [])
            for post in posts:
                q = post.get("question") or {}
                qid = q.get("id")
                title = q.get("title") or post.get("title") or ""
                if qid is not None:
                    listing_by_qid[qid] = title
            print(f"  Tournament {tid}: {len(posts)} posts fetched")
        except Exception as e:
            print(f"  ⚠️  Tournament {tid}: {e}")

    if not listing_by_qid:
        report.add("Live tournament consistency", True, "no open questions found to check")
        return

    live_titles = fetch_titles_by_question_id(list(listing_by_qid.keys()))

    mismatches = []
    not_found = []
    for qid, listing_title in listing_by_qid.items():
        detail_title = live_titles.get(qid)
        if detail_title is None:
            not_found.append((qid, listing_title))
            continue
        if not titles_match(listing_title, detail_title):
            mismatches.append((qid, listing_title, detail_title))

    if not quiet:
        for qid, lt, dt in mismatches:
            print(f"  🛑 MISMATCH Q{qid}: listing says '{lt[:60]}', detail says '{dt[:60]}'")
        for qid, lt in not_found[:20]:
            print(f"  ℹ️  Q{qid} ('{lt[:60]}'): not returned by detail (?ids=) fetch")

    report.add(
        "Live tournament consistency (listing vs detail endpoint)",
        len(mismatches) == 0,
        f"{len(mismatches)} mismatch(es), {len(not_found)} not found, "
        f"out of {len(listing_by_qid)} currently open questions checked"
    )


# ─────────────────────────────────────────────────────────────────────────
# CHECK D — meta_refresh_forecast.py's post_id path actually works live
# ─────────────────────────────────────────────────────────────────────────
def check_refresh_post_id_path(report: Report, quiet: bool):
    print("\n" + "-" * 60)
    print("CHECK D: does the FIXED meta_refresh_forecast.py post_id path "
          "actually fetch the right question, live?")
    print("-" * 60)

    entries = [e for e in load_history_entries() if e.get("post_id") is not None]
    if not entries:
        report.add(
            "Refresh post_id live fetch",
            True,
            "no post-fix entries with post_id on file yet — run a fresh batch "
            "or tournament cycle first, then re-run this check"
        )
        return

    try:
        from forecasting_tools import MetaculusClient, BinaryQuestion
    except Exception as e:
        report.add("Refresh post_id live fetch", False, f"could not import forecasting_tools: {e}")
        return

    client = MetaculusClient(token=TOKEN)

    # Sample up to 10 to keep this fast and avoid hammering the API every run
    sample = entries[:10]
    mismatches = []
    errors = []
    checked = 0

    for e in sample:
        time.sleep(SLEEP_BETWEEN_CALLS)
        try:
            result = client.get_question_by_post_id(e["post_id"])
            question = result[0] if isinstance(result, list) else result
            if not isinstance(question, BinaryQuestion):
                continue  # only binary supported by this path currently — skip silently
            checked += 1
            if not titles_match(e["question_text"], question.question_text or ""):
                mismatches.append((e, question.question_text))
        except Exception as ex:
            errors.append((e, str(ex)[:80]))

    if not quiet:
        for e, live_title in mismatches:
            print(f"  🛑 MISMATCH post {e['post_id']} (Q{e['question_id']}):")
            print(f"       Stored: {e['question_text'][:80]}")
            print(f"       Live:   {live_title[:80]}")
        for e, err in errors:
            print(f"  ⚠️  post {e['post_id']} (Q{e['question_id']}): fetch error — {err}")

    report.add(
        "Refresh post_id live fetch",
        len(mismatches) == 0,
        f"{checked} binary question(s) sampled and verified, "
        f"{len(mismatches)} mismatch(es), {len(errors)} fetch error(s)"
    )


# ─────────────────────────────────────────────────────────────────────────
# Main
# ─────────────────────────────────────────────────────────────────────────
def main():
    if not TOKEN:
        print("❌ No METAC_TOURNAMENT_TOKEN or METACULUS_TOKEN found in .env — cannot run.")
        sys.exit(1)

    args = sys.argv[1:]
    quiet = "--quiet" in args
    run_history = "--live" not in args
    run_live = "--history" not in args

    print("METACULUS PIPELINE SANITY CHECK")
    print("=" * 60)
    print(f"Run at: {datetime.now(timezone.utc).isoformat()}")
    print("Read-only — no forecasts, no submissions, no files written.")

    report = Report()

    if run_history:
        check_history_title_match(report, quiet)
        check_post_id_coverage(report, quiet)
    if run_live:
        check_live_tournament_consistency(report, quiet)
        check_refresh_post_id_path(report, quiet)

    all_passed = report.print_summary()
    sys.exit(0 if all_passed else 1)


if __name__ == "__main__":
    main()